# Cloudflare Pages — Security & Cache Headers
# https://brasa.world

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Cross-Origin-Embedder-Policy: unsafe-none
  Cross-Origin-Opener-Policy: same-origin-allow-popups

# HTML — always revalidate
/*.html
  Cache-Control: no-cache, must-revalidate
  Content-Type: text/html; charset=utf-8

/index.html
  Cache-Control: no-cache, must-revalidate

# CSS — 24 hour cache with immutable hint
/*.css
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
  Content-Type: text/css; charset=utf-8

# JS — 24 hour cache
/*.js
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Service worker — no cache (must always be fresh)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

# Manifest — 1 hour cache
/manifest.json
  Cache-Control: public, max-age=3600
  Content-Type: application/manifest+json

# Images — 30 day cache
/*.jpg
  Cache-Control: public, max-age=2592000, immutable
/*.png
  Cache-Control: public, max-age=2592000, immutable
/*.webp
  Cache-Control: public, max-age=2592000, immutable
/*.ico
  Cache-Control: public, max-age=2592000, immutable
/*.svg
  Cache-Control: public, max-age=2592000, immutable

# Fonts — 1 year cache
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable

# OG image — 24 hour cache
/og-image.jpg
  Cache-Control: public, max-age=86400

# Security: prevent access to config files
/.env
  X-Robots-Tag: noindex
/.git
  X-Robots-Tag: noindex
